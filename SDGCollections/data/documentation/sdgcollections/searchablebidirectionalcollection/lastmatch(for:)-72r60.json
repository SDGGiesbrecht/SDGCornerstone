lf","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Match","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"platforms":["Linux"]}]},{"kind":"parameters","parameters":[{"name":"pattern","content":[{"inlineContent":[{"text":"The pattern to search for.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This mathod searches backward from the end of the search range. This is not always the same thing as the last forward‐searched match:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let collection = [0, 0, 0, 0, 0]","let pattern = [0, 0]","","XCTAssertEqual(collection.lastMatch(for: pattern)?.range, 3..<5)","","XCTAssertEqual(collection.matches(for: pattern).last?.range, 2..<4)","\/\/ (Here the matches are 0 ..< 2 and 2 ..< 4; the final zero is incomplete.)"]},{"type":"codeListing","syntax":"swift","code":["let collection = [0, 0, 1]","let pattern = RepetitionPattern([0], count: 1..<Int.max, consumption: .lazy) + [1]","","XCTAssertEqual(collection.lastMatch(for: pattern)?.range, 1..<3)","\/\/ (Backwards, the pattern has already matched the 1, so the lazy consumption stops after the first 0 it encounteres.)","","XCTAssertEqual(collection.matches(for: pattern).last?.range, 0..<3)","\/\/ (Forwards, the lazy consumption keeps consuming zeros until the pattern can be completed with a one.)"]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SDGCollections\/documentation\/SDGCollections\/SearchableBidirectionalCollection\/lastMatch(for:)-72r60"},"references":{"doc://SDGCollections/documentation/SDGCollections/SearchableBidirectionalCollection/lastMatch(for:)-5re34":{"type":"topic","required":true,"abstract":[{"text":"Returns the last match for ","type":"text"},{"code":"pattern","type":"codeVoice"},{"type":"text","text":" in the