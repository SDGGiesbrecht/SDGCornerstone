{"defaultImplementationsSections":[{"identifiers":["doc:\/\/SDGCollections\/documentation\/SDGCollections\/SearchableBidirectionalCollection\/lastMatch(for:)-4jkaa","doc:\/\/SDGCollections\/documentation\/SDGCollections\/SearchableBidirectionalCollection\/lastMatch(for:)-72r60"],"title":"SearchableBidirectionalCollection Implementations"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["Linux"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"lastMatch"},{"kind":"text","text":"("},{"kind":"externalParam","text":"for"},{"kind":"text","text":" "},{"kind":"internalParam","text":"pattern"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Match"},{"kind":"text","text":"?"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"pattern","content":[{"inlineContent":[{"text":"The pattern to search for.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"text":"This mathod searches backward from the end of the search range. This is not always the same thing as the last forward‐searched match:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let collection = [0, 0, 0, 0, 0]","let pattern = [0, 0]","","XCTAssertEqual(collection.lastMatch(for: pattern)?.range, 3..<5)","","XCTAssertEqual(collection.matches(for: pattern).last?.range, 2..<4)","\/\/ (Here the matches are 0 ..< 2 and 2 ..< 4; the final zero is incomplete.)"]},{"syntax":"swift","type":"codeListing","code":["let collection = [0, 0, 1]","let pattern = RepetitionPattern([0], count: 1..<Int.max, consumption: .lazy) + [1]","","XCTAssertEqual(collection.lastMatch(for: pattern)?.range, 1..<3)","\/\/ (Backwards, the pattern has already matched the 1, so the lazy consumption stops after the first 0 it encounteres.)","","XCTAssertEqual(collection.matches(for: pattern).last?.range, 0..<3)","\/\/ (Forwards, the lazy consumption keeps consuming zeros until the pattern can be completed with a one.)"]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/SDGCollections\/documentation\/SDGCollections","doc:\/\/SDGCollections\/documentation\/SDGCollections\/SearchableBidirectionalCollection"]]},"variants":[{"paths":["\/documentation\/sdgcollections\/searchablebidirectionalcollection\/lastmatch(for:)-5re34"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SDGCollections\/documentation\/SDGCollections\/SearchableBidirectionalCollection\/lastMatch(for:)-5re34"},"abstract":[{"type":"text","text":"Returns the last match for "},{"type":"codeVoice","code":"pattern"},{"type":"text","text":" in the collection."}],"metadata":{"symbolKind":"method","externalID":"s:14SDGCollections33SearchableBidirectionalCollectionP9lastMatch3for0F0QzSgx_tF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"lastMatch","kind":"identifier"},{"text":"(","kind":"text"},{"text":"for","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Match","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"roleHeading":"Instance Method","role":"symbol","modules":[{"name":"SDGCollections"}],"required":true,"title":"lastMatch(for:)"},"references":{"doc://SDGCollections/documentation/SDGCollections/SearchableBidirectionalCollection":{"type":"topic","role":"symbol","title":"SearchableBidirectionalCollection","navigatorTitle":[{"text":"SearchableBidirectionalCollection","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text